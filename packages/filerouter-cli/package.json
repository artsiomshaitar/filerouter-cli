{
  "name": "filerouter-cli",
  "version": "0.1.0-alpha.1",
  "description": "A file-based routing framework for building CLI applications with TypeScript",
  "author": "Artsiom Shaitar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/artsiomshaitar/filerouter-cli.git",
    "directory": "packages/filerouter-cli"
  },
  "homepage": "https://github.com/artsiomshaitar/filerouter-cli#readme",
  "bugs": {
    "url": "https://github.com/artsiomshaitar/filerouter-cli/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "filerouter-cli": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "bun run build.ts",
    "dev": "bun run build.ts --watch",
    "prepublishOnly": "bun run build",
    "test": "bun test"
  },
  "dependencies": {
    "ink": "^7.0.0",
    "react": "^19.0.0"
  },
  "peerDependencies": {
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "bun-types": "latest",
    "typescript": "^5.0.0",
    "zod": "^3.23.0"
  },
  "keywords": ["cli", "router", "file-based", "typescript", "bun"],
  "license": "MIT"
}
