{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["bun-types"],
    "paths": {
      "filerouter-cli": ["./packages/filerouter-cli/src/index.ts"],
      "@filerouter-cli/generator": ["./packages/generator/src/index.ts"],
      "@filerouter-cli/generator/*": ["./packages/generator/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
