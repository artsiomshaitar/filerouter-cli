{
  "name": "filerouter-cli-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "example"
  ],
  "scripts": {
    "test": "bun test --cwd packages/filerouter-cli",
    "typecheck": "bunx tsc --noEmit -p packages/filerouter-cli/tsconfig.json",
    "build": "bun run --cwd packages/filerouter-cli build",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "format": "bunx biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "lefthook": "^2.1.4"
  }
}
